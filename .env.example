# ============================================================
# DayAgent 环境变量模板
# 部署时: cp .env.example .env && vim .env
# 本地开发: 复制到 agent_service/.env
# ============================================================

# ---- MySQL 数据库 ----
DB_PASSWORD=your-secure-password-here
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-secure-password-here
MYSQL_DB=dayagent

# ---- JWT ----
JWT_SECRET=generate-a-random-string-at-least-64-chars

# ---- Agent 服务地址 ----
AGENT_BASE_URL=http://agent-service:8000

# ---- LLM ----
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-v4-pro

# ---- 天气 ----
WEATHER_API_KEY=your-key-here
WEATHER_API_HOST=your-host-here

# ---- 新闻 ----
NEWS_API_KEY=your-key-here
NEWS_API_URL=https://apis.tianapi.com/guonei/index,https://apis.tianapi.com/world/index

# ---- 快递 100 ----
KUAIDI100_CUSTOMER=your-customer-id
KUAIDI100_KEY=your-key

# ---- 超星学习通 ----
CHAOXING_USERNAME=your-username
CHAOXING_PASSWORD=your-password

# ---- 位置与学期 ----
DEFAULT_LOCATION=南昌
SEMESTER_START=2026-03-09
