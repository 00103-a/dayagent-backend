  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.0.7",
    "wait-on": "^8.0.3"
  }
}
